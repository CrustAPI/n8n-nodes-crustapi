{
  "name": "n8n-nodes-crustapi",
  "version": "0.1.1",
  "description": "n8n community node for CrustAPI — Google Search, Maps, News, Shopping, Reviews and more as clean JSON.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "crustapi",
    "google",
    "serp",
    "scraper",
    "maps",
    "reviews"
  ],
  "license": "MIT",
  "homepage": "https://crustapi.com",
  "author": {
    "name": "CrustAPI",
    "email": "support@crustapi.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/88bricks/n8n-nodes-crustapi.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "lint": "eslint nodes credentials package.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CrustApiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CrustApi/CrustApi.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
